-- TÍNH NĂNG HITBOX (Nằm trong Tab Main)
----------------------------------------------------
local hitboxActive = false
local hitboxSize = Vector3.new(15, 15, 15) -- Kích thước khi phóng to

local HitboxButton = Instance.new("TextButton", MainTab)
HitboxButton.Size = UDim2.new(0, 300, 0, 50)
HitboxButton.Position = UDim2.new(0.5, -150, 0.3, -25)
HitboxButton.BackgroundColor3 = Color3.fromRGB(211, 84, 0) -- Màu đỏ cam mặc định (TẮT)
HitboxButton.Text = "⭕ Phóng To Hitbox Địch: TẮT"
HitboxButton.TextColor3 = Color3.fromRGB(255, 255, 255)
HitboxButton.TextSize = 16
HitboxButton.Font = Enum.Font.SourceSansBold
local HitboxCorner = Instance.new("UICorner", HitboxButton)
HitboxCorner.CornerRadius = UDim.new(0, 6)

-- Hàm xử lý cập nhật Hitbox
local function updateHitboxes()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                if hitboxActive then
                    -- Khi BẬT tính năng
                    hrp.Size = hitboxSize
                    hrp.Transparency = 0.7 -- Hơi trong suốt để dễ nhìn thấy khối hitbox
                    hrp.Color = Color3.fromRGB(255, 0, 0) -- Màu đỏ
                    hrp.CanCollide = false -- Tránh bị kẹt địa hình khi hitbox quá to
                else
                    -- Khi TẮT tính năng (Khôi phục mặc định)
                    hrp.Size = Vector3.new(2, 2, 1)
                    hrp.Transparency = 1
                    hrp.Color = Color3.fromRGB(255, 255, 255)
                    hrp.CanCollide = true
                end
            end
        end
    end
end

-- Lắng nghe sự kiện bật/tắt nút Hitbox
HitboxButton.MouseButton1Click:Connect(function()
    hitboxActive = not hitboxActive
    
    -- Cập nhật giao diện nút
    HitboxButton.Text = hitboxActive and "⭕ Phóng To Hitbox Địch: BẬT" or "⭕ Phóng To Hitbox Địch: TẮT"
    HitboxButton.BackgroundColor3 = hitboxActive and Color3.fromRGB(39, 174, 96) or Color3.fromRGB(211, 84, 0)
    
    -- Thực hiện quét ngay lập tức
    updateHitboxes()
end)

-- Vòng lặp duy trì liên tục (Đảm bảo người chơi mới hoặc hồi sinh cũng dính hitbox)
RunService.RenderStepped:Connect(function()
    if hitboxActive then
        updateHitboxes()
    end
end)

